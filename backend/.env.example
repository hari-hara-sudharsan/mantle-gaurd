# Existing database config, if needed by future persistence.
DATABASE_URL=

# Frontend origin for CORS.
FRONTEND_ORIGIN=http://localhost:3000

# Mantle Sepolia / audit registry config.
MANTLE_RPC_URL=https://rpc.sepolia.mantle.xyz
MANTLE_EXPLORER_URL=https://sepolia.mantlescan.xyz
AUDIT_LOGGER_ADDRESS=0xFc8cd61D26aF1A419B23F3bA08BE68aF3D9e827a

# Required only for real on-chain writes.
# Without these, /register-audit returns deterministic local proof data for demo continuity.
PRIVATE_KEY=
AUDIT_LOGGER_ABI_JSON=
AUDIT_LOGGER_FUNCTION=logAudit
AUDIT_LOGGER_GAS_LIMIT=250000

# Optional future AI provider config.
OPENAI_API_KEY=
